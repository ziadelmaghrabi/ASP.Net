@model IEnumerable<UniversityMVC.Models.Student>

<h2>All Students</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Age</th>
            <th>Department</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Age</td>
                <td>@(student.Department != null ? student.Department.Name : "No Department")</td>
                <td>
                    <a asp-action="ShowDetails" asp-route-id="@student.Id">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>
